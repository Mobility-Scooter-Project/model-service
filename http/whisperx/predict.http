@baseUrl = http://10.42.0.10/api/v1/whisperx
@jobId = REPLACE_WITH_JOB_ID

# Submit a WhisperX job through the async API.
POST {{baseUrl}}/jobs
Host: models.local
Content-Type: application/json

{
  "get_url": "https://js2.jetstream-cloud.org:8001/swift/v1/public/sample.m4a"
}

###

# Poll the job until it returns `status: succeeded`, then download the large
# JSON payload directly from the returned `result_get_url`.
GET {{baseUrl}}/jobs/{{jobId}}
Host: models.local

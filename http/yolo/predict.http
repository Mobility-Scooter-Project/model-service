@baseUrl = http://10.42.0.10/api/v1/yolo
@jobId = REPLACE_WITH_JOB_ID

# Submit a yolo job through the async API.
POST {{baseUrl}}/jobs
Host: models.local
Content-Type: application/json

{
  "get_url": "https://t4.ftcdn.net/jpg/02/24/86/95/360_F_224869519_aRaeLneqALfPNBzg0xxMZXghtvBXkfIA.jpg"
}

###

# Poll the job until it returns `status: succeeded`, then follow the
# `result_get_url` directly to MinIO.
GET {{baseUrl}}/jobs/{{jobId}}
Host: models.local

# Copy this file to `ghcr-pull-secret.local.yaml`, fill in your base64-encoded
# Docker config JSON, and apply it to the `model-service` namespace.
apiVersion: v1
kind: Secret
metadata:
  name: ghcr-pull-secret
  namespace: model-service
type: kubernetes.io/dockerconfigjson
data:
  .dockerconfigjson: BASE64_ENCODED_DOCKERCONFIGJSON

# Copy to `yolo.values.local.yaml` when you need to tweak tags/resources locally.
modelName: yolo
host: models.local
pathPrefix: /api/v1/yolo

image:
  repository: ghcr.io/mobility-scooter-project/model-service/yolo
  tag: garrett-terraform-local-refactor

api:
  replicas: 1
  resources:
    requests:
      cpu: "100m"
      memory: "256Mi"
    limits:
      cpu: "500m"
      memory: "512Mi"

worker:
  autoscaling:
    minReplicas: 0
    maxReplicas: 1
    listLength: 1
  resources:
    requests:
      cpu: "250m"
      memory: "1Gi"
    limits:
      cpu: "1000m"
      memory: "2Gi"

cache:
  size: 10Gi

hardwareProfile: cpu
